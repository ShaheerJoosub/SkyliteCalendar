@model IEnumerable<User>
@{
    ViewData["Title"] = "Staff";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Staff Members</h2>
    <a asp-action="Create" class="btn btn-primary">+ Add Staff Member</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No staff members yet. Add some to invite them to meetings.</div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@user.FullName</td>
                            <td class="text-muted">@user.Email</td>
                            <td>
                                @if (user.Department != null)
                                {
                                    <span class="badge" style="background:@user.Department.ColorHex">@user.Department.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline" onsubmit="return confirm('Remove @user.FullName?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
