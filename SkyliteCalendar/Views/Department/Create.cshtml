@model Department
@{
    ViewData["Title"] = "Add Department";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-4">Add Department</h2>
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Department Name</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Marketing" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ColorHex" class="form-label fw-semibold">Calendar Colour</label>
                        <div class="d-flex align-items-center gap-3">
                            <input asp-for="ColorHex" type="color" class="form-control form-control-color" style="width:60px;height:40px" value="#185FA5" />
                            <input asp-for="ColorHex" id="colorText" class="form-control" placeholder="#185FA5" style="font-family:monospace" />
                        </div>
                        <small class="text-muted">This colour will appear on the display board for this department's meetings.</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Department</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const picker = document.querySelector('input[type=color]');
    const text = document.getElementById('colorText');
    picker.addEventListener('input', () => text.value = picker.value);
    text.addEventListener('input', () => { if(/^#[0-9a-fA-F]{6}$/.test(text.value)) picker.value = text.value; });
</script>
}
