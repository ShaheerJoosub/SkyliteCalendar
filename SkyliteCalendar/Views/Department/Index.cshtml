@model IEnumerable<Department>
@{
    ViewData["Title"] = "Departments";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Departments</h2>
    <a asp-action="Create" class="btn btn-primary">+ Add Department</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No departments yet. Add one to get started.</div>
}
else
{
    <div class="row g-3">
        @foreach (var dept in Model)
        {
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div style="width:14px;height:48px;border-radius:4px;background:@dept.ColorHex;flex-shrink:0"></div>
                        <div class="flex-grow-1">
                            <h6 class="mb-0 fw-semibold">@dept.Name</h6>
                            <small class="text-muted">@dept.ColorHex</small>
                        </div>
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@dept.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <form asp-action="Delete" asp-route-id="@dept.Id" method="post" onsubmit="return confirm('Delete @dept.Name?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
